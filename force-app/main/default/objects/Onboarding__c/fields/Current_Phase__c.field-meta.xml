<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Current_Phase__c</fullName>
    <label>Current Phase</label>
    <formula>IF(ISBLANK(Day0_Date__c), "Pre-Phase",
IF(Current_Day__c &lt;= 7, "Phase 1",
IF(Current_Day__c &lt;= 30, "Phase 2",
IF(Current_Day__c &lt;= 60, "Phase 3",
IF(Current_Day__c &lt;= 90, "Phase 4", "Completed")))))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <type>Text</type>
</CustomField>
